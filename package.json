{
  "name": "rheo-swiftui",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build:swiftui": "pnpm --filter @rheo/swiftui build",
    "test:swiftui": "pnpm --filter @rheo/swiftui test",
    "verify": "pnpm build:swiftui && pnpm test:swiftui"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
