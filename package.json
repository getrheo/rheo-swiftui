{
  "name": "rheo-swiftui",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build:swiftui": "pnpm --filter @rheo/swiftui build",
    "test:swiftui": "pnpm --filter @rheo/swiftui test",
    "verify": "node scripts/check-no-platform-contracts.mjs && pnpm build:swiftui && pnpm test:swiftui"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript-eslint": "^8.59.0",
    "typescript": "^5.6.3",
    "tsup": "^8.5.1"
  }
}
